{
    "testId": "9f1922a6-01dd-4185-ac19-075aa402f1a3",
    "name": "SoundSnap",
    "version": "2.0.0",
    "manifestVersion": 2,
    "requirements": {
        "apps": [
            {
                "name": "Express",
                "apiVersion": 1
            }
        ]
    },
    "icon": [
        {
            "width": 24,
            "height": 24,
            "href": "assets/icon.png",
            "theme": ["all"]
        }
    ],
    "entryPoints": [
        {
            "type": "panel",
            "id": "panel1",
            "main": "index.html",
            "permissions": {
                "sandbox": ["allow-popups", "allow-popups-to-escape-sandbox", "allow-downloads"]
            }
        }
    ]
}
